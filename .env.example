# LLM API keys: configure in Settings (UI), not here
# NVIDIA: Get key at https://build.nvidia.com/ - use in Settings

# Image generation: configure in Settings → Article Images (UI)
# Stability AI: Get key at https://platform.stability.ai/account/keys
# AI Horde: Optional - use 0000000000 for anonymous, or register at https://stablehorde.net/

# Optional: Protect cron endpoint (set in Vercel Cron secret)
# CRON_SECRET=your-secret

# Optional: Custom SQLite path (default: ./data/app.db)
# DATABASE_PATH=./data/app.db